{
  "name": "ssafy-coffy",
  "private": true,
  "version": "1.7.0",
  "electronVersion": "1.3.0",
  "homepage": "https://KSJ0314.github.io/SSAFY_COFFY",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development nodemon --watch electron --ext cjs --exec 'electron electron/main.cjs'\"",
    "build": "tsc -b && vite build",
    "build:electron": "cross-env ELECTRON=true CSC_IDENTITY_AUTO_DISCOVERY=false npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "build": {
    "appId": "com.ssafy.coffy",
    "productName": "SSAFY_COFFEE",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "!dist/*.exe",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/favicon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "artifactName": "SSAFY_COFFEE_Setup.exe"
    }
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "html-to-image": "^1.11.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  }
}
